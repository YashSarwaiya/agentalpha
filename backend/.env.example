# The only key the chat needs. Get one at https://console.anthropic.com
# (Leave unset to run in playbooks-only mode — try "make a Minervini agent".)
ANTHROPIC_API_KEY=

# Optional: your own Postgres with a `stocks` table (see README → Bring your own data).
# When unset, the screener uses the bundled synthetic sample universe.
DATABASE_URL=

# Optional overrides
# BUILDER_MODEL=claude-haiku-4-5-20251001
# NEWS_AGENTS_ENABLED=0          # must match NEWS_ENABLED in AgentInterview.tsx
# AGENT_BUILD_DAILY_BUDGET_USD=1.00   # daily LLM spend cap for the builder
